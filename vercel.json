{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!.*\\.).*)","destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 6 * * 0"
    }
  ]
}
