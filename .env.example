# ── Server-side secrets (never expose to the browser) ──────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
# Set this in Vercel → Project Settings → Environment Variables
# For local development, add it to .env.local (no VITE_ prefix)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Supabase (safe to expose — protected by Row Level Security) ────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# VITE_ prefix makes them available in the browser bundle (intentional)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Supabase server-side (never expose to the browser) ─────────────────────────
# Used by the weekly-digest cron job to read all users' data
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (email delivery) ────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
